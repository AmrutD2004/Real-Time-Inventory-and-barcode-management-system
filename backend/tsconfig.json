{
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "esnext",

    "types": ["node"],

    "sourceMap": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,

    "strict": true,
    "esModuleInterop": true,

    "skipLibCheck": true
  }
}
